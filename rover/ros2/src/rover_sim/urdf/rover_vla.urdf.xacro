<?xml version="1.0"?>
<!--
  1/16 Ackermann rover for the VLA sim (openspec: rover-vla-sim-first, M0).

  Vehicle geometry, inertials, joint limits and the ros2_control layout are a
  verbatim copy of ackermann_rover_humble/src/description_robot's
  ackermann_rover.urdf (the real vehicle's digital twin). Removed relative to
  the source: RealSense d435i/l515, T265, RPLidar, CubePilot and all PX4 SITL
  branches, plus the 42 MB chassis mesh (primitive visuals instead — the
  forward camera never sees the ego body; collisions were already primitive).

  Added: the VLA forward camera, locked to the selected real sensor
  (OV9782 global-shutter color, 1280x800, ~100 deg HFOV — see tasks.md 1.2).
  Mount geometry (vla_cam_*) is provisional until the real mount exists.
-->
<robot name="ackermann" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:property name="PI" value="3.14159265"/>

  <xacro:property name="wheel_separation" value="0.174"/>
  <xacro:property name="wheel_base" value="0.174"/>
  <xacro:property name="wheel_diameter" value="0.077"/>
  <xacro:property name="wheel_thickness" value="0.024"/>
  <xacro:property name="base_elevation" value="0.01"/>

  <!-- VLA camera mount (provisional; locked at M3 hardware bring-up) -->
  <xacro:property name="vla_cam_x" value="${wheel_base/2 + 0.10}"/>
  <xacro:property name="vla_cam_z" value="0.15"/>
  <xacro:property name="vla_cam_pitch" value="0.0"/>
  <!-- OV9782 nominal: 1280x800, HFOV 100 deg -> fx = 640/tan(50 deg) = 537 -->
  <xacro:property name="vla_cam_hfov" value="${100.0*PI/180.0}"/>
  <xacro:property name="vla_cam_width" value="1280"/>
  <xacro:property name="vla_cam_height" value="800"/>
  <xacro:property name="vla_cam_rate" value="15"/>

  <xacro:arg name="ns" default="ackermann"/>

  <material name="gray">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <link name="$(arg ns)/base_footprint"/>

  <joint name="$(arg ns)/base_joint" type="fixed">
    <parent link="$(arg ns)/base_link"/>
    <child link="$(arg ns)/base_footprint"/>
    <origin xyz="0 0 ${-base_elevation}" rpy="0 0 0"/>
  </joint>

  <link name="$(arg ns)/base_link">
    <visual>
      <origin xyz="${wheel_base/2} 0 .06" rpy="0 0 0"/>
      <geometry>
        <box size=".3 .09 .12"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="${wheel_base/2} 0 .06" rpy="0 0 0"/>
      <geometry>
        <box size=".3 .09 .12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="${wheel_base/2} 0 ${wheel_diameter-base_elevation}" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia ixx="0.0054" ixy="0.0" ixz="0.0"
               iyy="0.0252" iyz="0.0"
               izz="0.0252"/>
    </inertial>
  </link>

  <!-- Wheel macro: visual + collision + inertial identical across corners -->
  <xacro:macro name="wheel_link" params="name collision_y_offset">
    <link name="$(arg ns)/${name}_link">
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00003331" ixy="0.0" ixz="0.0"
                 iyy="0.0000204" iyz="0.0"
                 izz="0.0000204"/>
      </inertial>
      <visual>
        <origin xyz="0 ${collision_y_offset} 0" rpy="${-PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_diameter/2}" length="${wheel_thickness}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 ${collision_y_offset} 0" rpy="${-PI/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_diameter/2}" length="0.03"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu value="0.5"/>
              <mu2 value="1.0"/>
              <fdir1 value="0 0 1"/>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>
  </xacro:macro>

  <!-- Front wheels: steering knuckle (revolute) + spinning wheel (continuous) -->
  <xacro:macro name="front_corner" params="side y_sign collision_y_offset">
    <joint name="$(arg ns)/front_${side}_wheel_steering_joint" type="revolute">
      <origin xyz="${wheel_base} ${y_sign*wheel_separation/2} 0" rpy="0 0 0"/>
      <parent link="$(arg ns)/base_link"/>
      <child link="$(arg ns)/front_${side}_wheel_steering_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.6" upper="0.6" effort="25" velocity="1"/>
    </joint>
    <link name="$(arg ns)/front_${side}_wheel_steering_link">
      <inertial>
        <mass value="0.005"/>
        <inertia ixx="0.0000018" ixy="0.0" ixz="0.0"
                 iyy="0.0000018" iyz="0.0"
                 izz="0.0000018"/>
      </inertial>
    </link>
    <joint name="$(arg ns)/front_${side}_wheel_joint" type="continuous">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="$(arg ns)/front_${side}_wheel_steering_link"/>
      <child link="$(arg ns)/front_${side}_wheel_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1e16" upper="1e16" effort="100" velocity="100"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>
    <xacro:wheel_link name="front_${side}_wheel" collision_y_offset="${collision_y_offset}"/>
  </xacro:macro>

  <!-- Rear wheels: driven, fixed heading -->
  <xacro:macro name="rear_corner" params="side y_sign collision_y_offset">
    <joint name="$(arg ns)/rear_${side}_wheel_joint" type="continuous">
      <origin xyz="0 ${y_sign*wheel_separation/2} 0" rpy="0 0 0"/>
      <parent link="$(arg ns)/base_link"/>
      <child link="$(arg ns)/rear_${side}_wheel_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1e16" upper="1e16" effort="100" velocity="100"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>
    <xacro:wheel_link name="rear_${side}_wheel" collision_y_offset="${collision_y_offset}"/>
  </xacro:macro>

  <xacro:front_corner side="left"  y_sign="1"  collision_y_offset="-0.015"/>
  <xacro:front_corner side="right" y_sign="-1" collision_y_offset="0.015"/>
  <xacro:rear_corner  side="left"  y_sign="1"  collision_y_offset="-0.015"/>
  <xacro:rear_corner  side="right" y_sign="-1" collision_y_offset="0.015"/>

  <!-- VLA forward camera (OV9782-locked) -->
  <joint name="$(arg ns)/vla_camera_joint" type="fixed">
    <parent link="$(arg ns)/base_link"/>
    <child link="$(arg ns)/vla_camera_link"/>
    <origin xyz="${vla_cam_x} 0 ${vla_cam_z}" rpy="0 ${vla_cam_pitch} 0"/>
  </joint>
  <link name="$(arg ns)/vla_camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.03 0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
               iyy="0.000001" iyz="0.0"
               izz="0.000001"/>
    </inertial>
  </link>
  <!-- ROS optical frame convention (z forward, x right, y down) -->
  <joint name="$(arg ns)/vla_camera_optical_joint" type="fixed">
    <parent link="$(arg ns)/vla_camera_link"/>
    <child link="$(arg ns)/vla_camera_optical"/>
    <origin xyz="0 0 0" rpy="${-PI/2} 0 ${-PI/2}"/>
  </joint>
  <link name="$(arg ns)/vla_camera_optical"/>

  <gazebo reference="$(arg ns)/vla_camera_link">
    <sensor name="vla_camera" type="camera">
      <update_rate>${vla_cam_rate}</update_rate>
      <!-- For type="camera", <topic> is the image topic itself (unlike
           rgbd_camera where it is a prefix); camera_info must be set too. -->
      <topic>vla_camera/image</topic>
      <gz_frame_id>$(arg ns)/vla_camera_optical</gz_frame_id>
      <camera>
        <camera_info_topic>vla_camera/camera_info</camera_info_topic>
        <horizontal_fov>${vla_cam_hfov}</horizontal_fov>
        <image>
          <width>${vla_cam_width}</width>
          <height>${vla_cam_height}</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>50.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
    </sensor>
  </gazebo>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="$(arg ns)/rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="$(arg ns)/rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="$(arg ns)/front_left_wheel_joint">
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="$(arg ns)/front_right_wheel_joint">
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="$(arg ns)/front_left_wheel_steering_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="$(arg ns)/front_right_wheel_steering_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find rover_sim)/config/controllers.yaml</parameters>
      <ros>
        <namespace></namespace>
        <remapping>ackermann_steering_controller/reference:=cmd_vel</remapping>
        <remapping>ackermann_steering_controller/reference_unstamped:=cmd_vel_unstamped</remapping>
      </ros>
    </plugin>

    <!-- Ground-truth world pose at 50 Hz: the label source for the recorder -->
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>$(arg ns)/base_link</robot_base_frame>
      <odom_topic>$(arg ns)/gt_odom</odom_topic>
      <odom_publish_frequency>50</odom_publish_frequency>
      <publish_tf>false</publish_tf>
    </plugin>
  </gazebo>

</robot>
